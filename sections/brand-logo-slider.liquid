<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>

{% liquid
  assign section_width = section.settings.section_width | default: 'page-width'
  
  if section.settings.bg_color != blank
    render 'contrast-override', background_color: section.settings.bg_color, section_id: section.id
  endif
%}

<style>
  #shopify-section-{{ section.id }} .brand-slider-section {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2400 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% elsif section.settings.bg_gradient != blank %}
      background: {{ section.settings.bg_gradient }};
    {% endif %}
    width: 100%;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .brand-slider {
    min-height: {{ section.settings.min_height | default: 200 }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .brand-slider-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  #brand-slider-swiper-{{ section.id }}.swiper-marquee-active .swiper-wrapper {
    transition-timing-function: linear !important;
  }

  /* Header styles */
  .brand-slider__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 32px;
  }

  .brand-slider__heading {
    margin: 0 0 8px;
    font-size: {{ section.settings.heading_font_size | default: 28 }}px;
    font-weight: 600;
    color: {{ section.settings.heading_color | default: 'var(--color-foreground)' }};
    font-family: var(--font-heading--family);
  }

  @media screen and (max-width: 749px) {
    .brand-slider__heading {
      font-size: {{ section.settings.heading_font_size_mobile | default: 22 }}px;
    }
  }

  .brand-slider__heading-line {
    width: 60px;
    height: 3px;
    background-color: var(--color-primary-button-background);
    border-radius: 2px;
  }

  /* Carousel container & swiper wrapper styles */
  .brand-slider__carousel-container {
    position: relative;
    width: 100%;
    padding: 0 48px; /* Room for arrows */
  }

  @media screen and (max-width: 749px) {
    .brand-slider__carousel-container {
      padding: 0 16px;
    }
  }

  .brand-slider-swiper {
    width: 100%;
    overflow: hidden;
  }

  /* Brand Logo item styling */
  .brand-logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ section.settings.logo_height | default: 80 }}px;
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }

  .brand-logo-item:hover {
    opacity: 1;
  }

  .brand-logo-item__image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .brand-logo-item__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f7f7f7;
    border-radius: 4px;
    color: #999999;
    font-size: 14px;
    font-weight: 500;
    font-family: var(--font-body--family);
  }

  /* Custom navigation arrows */
  .brand-slider-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    color: #333333;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.2s ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
  }

  .brand-slider-arrow:hover {
    background: #f7f7f7;
    border-color: #cccccc;
  }

  .brand-slider-arrow.swiper-button-disabled {
    opacity: 0;
    cursor: default;
    pointer-events: none;
  }

  .brand-slider-arrow--prev {
    left: 8px;
  }

  .brand-slider-arrow--next {
    right: 8px;
  }

  @media screen and (max-width: 749px) {
    .brand-slider-arrow {
      display: none; /* Hide arrows on mobile for swipe scroll */
    }
  }
</style>

<div class="brand-slider-section">
  <div
    class="section section--{{ section_width }}{% if section_width == 'custom' %} section--page-width section--custom-width{% endif %}"
    style="
      {% if section_width == 'custom' %}
        --page-content-width: {{ section.settings.custom_max_width | default: 1400 }}px;
        --page-width: calc({{ section.settings.custom_max_width | default: 1400 }}px + (var(--page-margin) * 2));
        max-width: {{ section.settings.custom_max_width }}px;
        margin: 0 auto;
      {% endif %}
    "
  >
    <div class="brand-slider">
      {%- if section.settings.heading != blank -%}
        <div class="brand-slider__header">
          <h2 class="brand-slider__heading">{{ section.settings.heading }}</h2>
          <div class="brand-slider__heading-line"></div>
        </div>
      {%- endif -%}

      <div class="brand-slider__carousel-container">
        <!-- Navigation Arrows -->
        <div class="brand-slider-arrow brand-slider-arrow--prev swiper-button-prev-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px; height:20px;"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </div>
        <div class="brand-slider-arrow brand-slider-arrow--next swiper-button-next-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px; height:20px;"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>

        <div class="swiper brand-slider-swiper" id="brand-slider-swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            {%- if section.blocks.size > 0 -%}
              {%- assign repeat_count = 1 -%}
              {%- if section.blocks.size < 18 -%}
                {%- if section.blocks.size < 5 -%}
                  {%- assign repeat_count = 5 -%}
                {%- elsif section.blocks.size < 9 -%}
                  {%- assign repeat_count = 3 -%}
                {%- else -%}
                  {%- assign repeat_count = 2 -%}
                {%- endif -%}
              {%- endif -%}

              {%- for i in (1..repeat_count) -%}
                {%- for block in section.blocks -%}
                  <div class="swiper-slide" {% if i == 1 %}{{ block.shopify_attributes }}{% endif %}>
                    {%- if block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}" class="brand-logo-item" style="display: flex; width: 100%;">
                    {%- else -%}
                      <div class="brand-logo-item">
                    {%- endif -%}

                    {%- if block.settings.image != blank -%}
                      <img
                        class="brand-logo-item__image"
                        src="{{ block.settings.image | image_url: width: 400 }}"
                        alt="{{ block.settings.image.alt | default: 'Brand Logo' }}"
                        loading="lazy"
                        width="150"
                      >
                    {%- else -%}
                      <!-- Elegant name placeholder matching user screenshot -->
                      <div class="brand-logo-item__placeholder">
                        Brand Logo
                      </div>
                    {%- endif -%}

                    {%- if block.settings.link != blank -%}
                      </a>
                    {%- else -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    function initBrandSwiper() {
      var swiperContainer = document.querySelector('#brand-slider-swiper-{{ section.id }}');
      if (!swiperContainer) return;
      
      if (typeof Swiper === 'undefined') {
        setTimeout(initBrandSwiper, 100);
        return;
      }
      
      if (swiperContainer.swiper) {
        swiperContainer.swiper.destroy(true, true);
      }

      var autoplayEnabled = {{ section.settings.autoplay_enable | default: true }};
      var autoplayMode = "{{ section.settings.autoplay_mode | default: 'continuous' }}";
      var marqueeSpeed = {{ section.settings.marquee_speed | default: 4000 }};
      var slideDelay = {{ section.settings.slide_delay | default: 3 | times: 1000 }};
      var direction = "{{ section.settings.autoplay_direction | default: 'rtl' }}";
      var pauseOnHover = {{ section.settings.pause_on_hover | default: true }};
      var dragToSlide = {{ section.settings.drag_to_slide | default: true }};

      var swiperOptions = {
        slidesPerView: 6,
        spaceBetween: 24,
        loop: true,
        loopAdditionalSlides: 6,
        allowTouchMove: dragToSlide,
        navigation: {
          nextEl: '.swiper-button-next-{{ section.id }}',
          prevEl: '.swiper-button-prev-{{ section.id }}',
        },
        breakpoints: {
          320: {
            slidesPerView: 2.5,
            spaceBetween: 16
          },
          480: {
            slidesPerView: 3.5,
            spaceBetween: 16
          },
          768: {
            slidesPerView: 5,
            spaceBetween: 20
          },
          1024: {
            slidesPerView: 6,
            spaceBetween: 24
          }
        }
      };

      if (autoplayEnabled) {
        var delayVal = autoplayMode === 'continuous' ? 0 : slideDelay;
        var speedVal = autoplayMode === 'continuous' ? marqueeSpeed : 400;

        swiperOptions.speed = speedVal;
        swiperOptions.autoplay = {
          delay: delayVal,
          disableOnInteraction: false,
          pauseOnMouseEnter: pauseOnHover,
          reverseDirection: direction === 'ltr'
        };
      }

      var swiper = new Swiper(swiperContainer, swiperOptions);

      if (autoplayEnabled && autoplayMode === 'continuous') {
        swiperContainer.classList.add('swiper-marquee-active');

        swiper.on('autoplayPause', function() {
          swiperContainer.classList.remove('swiper-marquee-active');
        });

        swiper.on('autoplayResume', function() {
          swiperContainer.classList.add('swiper-marquee-active');
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBrandSwiper);
    } else {
      initBrandSwiper();
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === '{{ section.id }}') {
        setTimeout(initBrandSwiper, 100);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Brand Logo Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Favourite Brands"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size (desktop)",
      "min": 16,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading Font Size (mobile)",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo Max Height (desktop)",
      "min": 30,
      "max": 180,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay_enable",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "select",
      "id": "autoplay_mode",
      "label": "Autoplay Mode",
      "options": [
        {
          "value": "continuous",
          "label": "Continuous Scroll (Marquee)"
        },
        {
          "value": "slide",
          "label": "Slide by Slide"
        }
      ],
      "default": "continuous"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee Speed / Transition Duration",
      "min": 1000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "default": 4000,
      "info": "Time taken to slide from one logo to next. Lower value = faster speed."
    },
    {
      "type": "range",
      "id": "slide_delay",
      "label": "Slide Delay (Slide-by-Slide mode only)",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 3,
      "info": "Time spent on each slide before moving to the next."
    },
    {
      "type": "select",
      "id": "autoplay_direction",
      "label": "Autoplay Direction",
      "options": [
        {
          "value": "rtl",
          "label": "Right to Left"
        },
        {
          "value": "ltr",
          "label": "Left to Right"
        }
      ],
      "default": "rtl"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "drag_to_slide",
      "label": "Enable Mouse Drag / Touch Swipe",
      "default": true
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "custom",
          "label": "Custom Max Width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "custom_max_width",
      "label": "Custom Max Width",
      "min": 1000,
      "max": 2000,
      "step": 10,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum Height (desktop)",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "header",
      "content": "Background Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Background Gradient"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "brand_logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logo Slider",
      "blocks": [
        { "type": "brand_logo" },
        { "type": "brand_logo" },
        { "type": "brand_logo" },
        { "type": "brand_logo" },
        { "type": "brand_logo" },
        { "type": "brand_logo" },
        { "type": "brand_logo" }
      ]
    }
  ]
}
{% endschema %}
