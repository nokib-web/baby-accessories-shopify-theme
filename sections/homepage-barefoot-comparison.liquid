    },
    {
      "type": "text",
      "id": "trad_item_2_title",
      "label": "Item 2 Title",
      "default": "Stiff & Heavy Soles"
    },
    {
      "type": "text",
      "id": "trad_item_2_desc",
      "label": "Item 2 Description",
      "default": "Restricts natural foot flexing. Weakens arches and ankle muscles, causing dependency on shoe support."
    },
    {
      "type": "text",
      "id": "trad_item_3_title",
      "label": "Item 3 Title",
      "default": "Elevated Heels (Drop)"
    },
    {
      "type": "text",
      "id": "trad_item_3_desc",
      "label": "Item 3 Description",
      "default": "Alters natural posture, throwing off body balance and putting unnecessary stress on toddler knees and hips."
    },
    {
      "type": "header",
      "content": "Barefoot Column Settings"
    },
    {
      "type": "text",
      "id": "bf_title",
      "label": "Barefoot Shoes Title",
      "default": "Little Leaf Barefoot Shoes"
    },
    {
      "type": "image_picker",
      "id": "bf_image",
      "label": "Barefoot Shoe Image"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Feature Badge Label",
      "default": "Healthy Growth"
    },
    {
      "type": "text",
      "id": "bf_item_1_title",
      "label": "Item 1 Title",
      "default": "Wide, Foot-Shaped Toe Box"
    },
    {
      "type": "text",
      "id": "bf_item_1_desc",
      "label": "Item 1 Description",
      "default": "Gives toes ample room to splay naturally, providing excellent stability, balance, and straight toe alignment."
    },
    {
      "type": "text",
      "id": "bf_item_2_title",
      "label": "Item 2 Title",
      "default": "Ultra-Flexible, Thin Soles"
    },
    {
