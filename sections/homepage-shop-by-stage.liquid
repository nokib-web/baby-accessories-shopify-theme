{% liquid
  assign section_width = section.settings.section_width | default: 'custom'
  
  if section.settings.bg_color != blank
    render 'contrast-override', background_color: section.settings.bg_color, section_id: section.id
  endif
%}

<style>
  #shopify-section-{{ section.id }} .shop-by-stage-section {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    width: 100%;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    box-sizing: border-box;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .shop-by-stage-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  /* Header styles */
  .shop-by-stage__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 40px;
    padding: 0 20px;
  }

  .shop-by-stage__heading {
    margin: 0 0 12px;
    font-size: {{ section.settings.heading_font_size | default: 32 }}px;
    font-weight: 600;
    color: {{ section.settings.heading_color | default: '#2e4a29' }};
    font-family: var(--font-heading--family), Outfit, Inter, sans-serif;
    line-height: 1.2;
  }

  .shop-by-stage__subheading {
    margin: 0 0 16px;
    font-size: 16px;
    color: #555555;
    max-width: 600px;
    line-height: 1.5;
  }

  .shop-by-stage__heading-line {
    width: 60px;
    height: 3px;
    background-color: {{ section.settings.accent_color | default: '#2e4a29' }};
    border-radius: 2px;
  }

  @media screen and (max-width: 749px) {
    .shop-by-stage__heading {
      font-size: {{ section.settings.heading_font_size_mobile | default: 24 }}px;
    }
    .shop-by-stage__subheading {
      font-size: 14px;
    }
    .shop-by-stage__header {
      margin-bottom: 24px;
    }
  }

  /* Grid layout */
  .shop-by-stage__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | default: 3 }}, 1fr);
    gap: 30px;
    padding: 0 20px;
    box-sizing: border-box;
    width: 100%;
  }

  @media screen and (max-width: 990px) {
    .shop-by-stage__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media screen and (max-width: 550px) {
    .shop-by-stage__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  /* Card styling */
  .shop-by-stage__card {
    background: {{ section.settings.card_bg_color | default: '#f4f6f1' }};
    border: 1px solid #eef1ea;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .shop-by-stage__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(46, 74, 41, 0.08);
  }

  .shop-by-stage__image-wrapper {
    position: relative;
    width: 100%;
    height: 280px;
    background-color: transparent;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shop-by-stage__image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  @media screen and (max-width: 749px) {
    .shop-by-stage__image-wrapper {
      height: 220px;
    }
  }

  .shop-by-stage__card:hover .shop-by-stage__image {
    transform: scale(1.05);
  }

  .shop-by-stage__content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    align-items: center;
    text-align: center;
  }

  .shop-by-stage__card-age {
    font-size: 13px;
    font-weight: 600;
    color: {{ section.settings.accent_color | default: '#2e4a29' }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .shop-by-stage__card-title {
    font-size: 20px;
    font-weight: 600;
    color: #091208;
    margin: 0 0 12px 0;
    font-family: var(--font-heading--family), Outfit, Inter, sans-serif;
  }

  .shop-by-stage__card-desc {
    font-size: 14px;
    color: #555555;
    line-height: 1.5;
    margin: 0 0 20px 0;
    flex-grow: 1;
  }

  .shop-by-stage__card-btn {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 600;
    color: {{ section.settings.accent_color | default: '#2e4a29' }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
    gap: 6px;
    transition: gap 0.2s ease;
  }

  .shop-by-stage__card:hover .shop-by-stage__card-btn {
    gap: 10px;
  }

  .shop-by-stage__card-btn svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
    transition: transform 0.2s ease;
  }
</style>

<div class="shop-by-stage-section">
  <div
    class="section section--{{ section_width }}{% if section_width == 'custom' %} section--page-width section--custom-width{% endif %}"
    style="
      {% if section_width == 'custom' %}
        --page-content-width: {{ section.settings.custom_max_width | default: 1600 }}px;
        --page-width: calc({{ section.settings.custom_max_width | default: 1600 }}px + (var(--page-margin) * 2));
        max-width: {{ section.settings.custom_max_width | default: 1600 }}px;
        margin: 0 auto;
      {% endif %}
    "
  >
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="shop-by-stage__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="shop-by-stage__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="shop-by-stage__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <div class="shop-by-stage__heading-line"></div>
      </div>
    {%- endif -%}

    <div class="shop-by-stage__grid">
      {%- for block in section.blocks -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="shop-by-stage__card" {{ block.shopify_attributes }}>
        {%- else -%}
          <div class="shop-by-stage__card" {{ block.shopify_attributes }}>
        {%- endif -%}

        <div class="shop-by-stage__image-wrapper">
          {%- if block.settings.image != blank -%}
            <img
              class="shop-by-stage__image"
              src="{{ block.settings.image | image_url: width: 600 }}"
              alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
              loading="lazy"
              width="400"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg shop-by-stage__image' }}
          {%- endif -%}
        </div>

        <div class="shop-by-stage__content">
          {%- if block.settings.age != blank -%}
            <span class="shop-by-stage__card-age">{{ block.settings.age }}</span>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="shop-by-stage__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="shop-by-stage__card-desc">{{ block.settings.description }}</p>
          {%- endif -%}
          <span class="shop-by-stage__card-btn">
            Shop Collection
            <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>

        {%- if block.settings.link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Shop by Stage",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Baby's Stage"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find exactly what your little explorer needs for their developmental journey."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#2e4a29"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#2e4a29"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size (desktop)",
      "min": 16,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading Font Size (mobile)",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Colors & Backgrounds"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#f4f6f1"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "custom",
          "label": "Custom Max Width"
        }
      ],
      "default": "custom"
    },
    {
      "type": "range",
      "id": "custom_max_width",
      "label": "Custom Max Width",
      "min": 1000,
      "max": 2000,
      "step": 10,
      "unit": "px",
      "default": 1600
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Stage Image"
        },
        {
          "type": "text",
          "id": "age",
          "label": "Age Group (e.g. 0-6 Months)",
          "default": "0-6 Months"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Stage Title",
          "default": "Newborn Essentials"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Short Description",
          "default": "Gentle organic clothing & non-toxic teethers designed for comfort and sensory exploration."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Stage",
      "blocks": [
        {
          "type": "stage",
          "settings": {
            "age": "0-6 Months",
            "title": "Tiny Explorers",
            "description": "GOTS certified organic cotton clothes and chemical-free teethers for soft skins."
          }
        },
        {
          "type": "stage",
          "settings": {
            "age": "6-12 Months",
            "title": "Active Crawlers",
            "description": "Flexible wear built for mobility and teethers with textured sensory surfaces."
          }
        },
        {
          "type": "stage",
          "settings": {
            "age": "12-24M+",
            "title": "First Steps",
            "description": "Orthopedic-approved barefoot shoes and active organic sets for safe walking."
          }
        }
      ]
    }
  ]
}
{% endschema %}
