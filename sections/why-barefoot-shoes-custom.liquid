<style>
  /* Tighten spacing between blocks in the details column */
  .text-block--text_n6rb8K h2 {
    font-size: 2.4rem !important;
    font-weight: 700 !important;
    color: {{ section.settings.heading_color | default: '#2e4a29' }} !important;
    text-align: center !important;
    margin-bottom: 30px !important;
    font-family: var(--font-heading--family), Outfit, Inter, sans-serif !important;
    line-height: 1.2 !important;
  }
  
  .text-block--text_n6rb8K {
    width: 100% !important;
    text-align: center !important;
  }

  /* Make sure the text block has full width for the grid */
  .text-block--text_Uidqpe {
    width: 100% !important;
    max-width: 1200px !important;
    margin-left: auto !important;
    margin-right: auto !important;
    padding: 0 20px !important;
  }

  .text-block--text_Uidqpe rte-formatter {
    max-width: 100% !important;
    width: 100% !important;
  }

  /* Grid container styling */
  .features-grid {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 24px !important;
    width: 100% !important;
    margin-top: 20px !important;
  }

  @media screen and (max-width: 990px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media screen and (max-width: 749px) {
    .features-grid {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }
  }

  /* Individual card styling */
  .feature-card {
    background: {{ section.settings.card_bg_color | default: '#ffffff' }} !important;
    border: 1px solid #eef1ea !important;
    border-radius: 12px !important;
    padding: 28px 24px !important;
    box-shadow: 0 4px 15px rgba(46, 74, 41, 0.03) !important;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease !important;
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
  }

  .feature-card:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 8px 25px rgba(46, 74, 41, 0.08) !important;
    border-color: {{ section.settings.card_title_color | default: '#2e4a29' }} !important;
  }

  /* Title inside the card */
  .feature-card__title {
    font-size: 1.3rem !important;
    font-weight: 700 !important;
    color: {{ section.settings.card_title_color | default: '#2e4a29' }} !important;
    margin: 0 0 12px 0 !important;
    font-family: var(--font-heading--family), Outfit, Inter, sans-serif !important;
    line-height: 1.3 !important;
  }

  /* Paragraph text inside the card */
  .feature-card__text {
    font-size: 0.95rem !important;
    line-height: 1.6 !important;
    color: {{ section.settings.card_text_color | default: '#4a4a4a' }} !important;
    margin: 0 !important;
    font-family: var(--font-body--family), Inter, sans-serif !important;
    flex-grow: 1 !important;
  }
</style>

<script>
  (function() {
    function initWhyBarefootPage() {
      // Target the text block container
      const textBlock = document.querySelector('.text-block--text_Uidqpe rte-formatter');
      if (!textBlock) return;

      if (textBlock.classList.contains('transformed-to-grid')) return;

      // Extract titles and text from paragraphs
      const paragraphs = Array.from(textBlock.querySelectorAll('p'));
      if (paragraphs.length === 0) return;

      const cards = [];
      let currentCard = null;

      paragraphs.forEach(p => {
        const strong = p.querySelector('strong');
        const text = p.textContent.trim();

        if (strong && text.startsWith(strong.textContent.trim())) {
          // If this paragraph has a bold title at the start
          if (currentCard) {
            cards.push(currentCard);
          }
          currentCard = {
            title: strong.textContent.trim(),
            paragraphs: [text.replace(strong.textContent.trim(), '').trim()]
          };
        } else if (currentCard) {
          currentCard.paragraphs.push(text);
        }
      });

      if (currentCard) {
        cards.push(currentCard);
      }

      if (cards.length === 0) return;

      // Build the new grid HTML
      let gridHTML = '<div class="features-grid">';
      cards.forEach(card => {
        gridHTML += `
          <div class="feature-card">
            <h3 class="feature-card__title">${card.title}</h3>
            <p class="feature-card__text">${card.paragraphs.join(' ')}</p>
          </div>
        `;
      });
      gridHTML += '</div>';

      // Replace the inner HTML and mark as transformed
      textBlock.innerHTML = gridHTML;
      textBlock.classList.add('transformed-to-grid');
    }

    // Run on page load
    document.addEventListener('DOMContentLoaded', initWhyBarefootPage);
    
    // Run immediately (if script loads after DOM is ready)
    if (document.readyState === 'interactive' || document.readyState === 'complete') {
      initWhyBarefootPage();
    }

    // Run inside Shopify editor when sections are updated/reloaded
    document.addEventListener('shopify:section:load', function(e) {
      setTimeout(initWhyBarefootPage, 100);
    });
    document.addEventListener('shopify:section:select', function(e) {
      setTimeout(initWhyBarefootPage, 100);
    });
  })();
</script>

{% schema %}
{
  "name": "Why Barefoot Custom",
  "settings": [
    {
      "type": "header",
      "content": "Color & Style Settings"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Main Heading Color",
      "default": "#2e4a29"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#2e4a29"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Why Barefoot Custom"
    }
  ]
}
{% endschema %}
