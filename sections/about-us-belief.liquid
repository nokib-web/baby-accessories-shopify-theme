<style>
  .about-belief-section-{{ section.id }} {
    {% if section.settings.background_color != blank %}
      background-color: {{ section.settings.background_color }};
    {% else %}
      background-color: transparent;
    {% endif %}
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
    padding-top: {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    text-align: center;
  }

  .about-belief-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .about-belief-header {
    margin-bottom: 40px;
  }

  .about-belief-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: {{ section.settings.title_color | default: '#2e4a29' }};
    margin: 0 0 12px 0;
    font-family: var(--font-heading--family), Outfit, Inter, sans-serif;
  }

  .about-belief-leaf {
    display: inline-block;
    color: {{ section.settings.leaf_color | default: '#a6b89c' }};
  }

  .about-belief-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 48px;
    align-items: center;
  }

  @media screen and (max-width: 749px) {
    .about-belief-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .about-belief-image-col {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .about-belief-image-circle {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 50%;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
    background-color: #f4f6f2;
    border: 1px solid rgba(46, 74, 41, 0.05);
  }

  .about-belief-image-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-belief-content-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .about-belief-text {
    font-size: 1.15rem;
    line-height: 1.8;
    color: {{ section.settings.text_color | default: '#4a4a4a' }};
    margin-bottom: 24px;
    font-family: var(--font-body--family), Inter, sans-serif;
  }

  .about-belief-highlight {
    font-size: 1.1rem;
    font-weight: 700;
    color: {{ section.settings.highlight_color | default: '#2e4a29' }};
    margin-bottom: 16px;
    font-family: var(--font-heading--family), Outfit, Inter, sans-serif;
  }

  .about-belief-closing {
    font-size: 1rem;
    font-weight: 700;
    color: {{ section.settings.closing_color | default: '#8c9c84' }};
    font-family: var(--font-body--family), Inter, sans-serif;
  }
</style>

<div class="about-belief-section-{{ section.id }}">
  <div class="about-belief-container">
    <div class="about-belief-header">
      {% if section.settings.title != blank %}
        <h2 class="about-belief-title">{{ section.settings.title }}</h2>
      {% endif %}
      <div class="about-belief-leaf">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.5 2 2 6.5 2 12c0 3 .5 5 1.5 6.5L12 12l8.5 6.5c1-1.5 1.5-3.5 1.5-6.5 0-5.5-4.5-10-10-10z"/></svg>
      </div>
    </div>

    <div class="about-belief-grid">
      <div class="about-belief-image-col">
        <div class="about-belief-image-circle">
          {% if section.settings.image != blank %}
            <img src="{{ section.settings.image | image_url: width: 600 }}" alt="{{ section.settings.title | strip_html }}" loading="lazy">
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>

      <div class="about-belief-content-col">
        {% if section.settings.text != blank %}
          <div class="about-belief-text">
            {{ section.settings.text }}
          </div>
        {% endif %}

        {% if section.settings.highlight_text != blank %}
          <div class="about-belief-highlight">
            {{ section.settings.highlight_text }}
          </div>
        {% endif %}

        {% if section.settings.closing_text != blank %}
          <div class="about-belief-closing">
            {{ section.settings.closing_text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Us Belief",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Our Belief"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Belief Content Paragraph",
      "default": "<p>We don’t believe babies need more things. We believe they need better ones...</p>"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlight Text",
      "default": "For your baby. For your family. For the world they'll grow up in. ♥"
    },
    {
      "type": "text",
      "id": "closing_text",
      "label": "Closing Text",
      "default": "Because the gentlest beginnings leave the deepest impressions."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Belief Image"
    },
    {
      "type": "header",
      "content": "Color & Typography Settings"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#2e4a29"
    },
    {
      "type": "color",
      "id": "leaf_color",
      "label": "Leaf Accent Color",
      "default": "#a6b89c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Paragraph Color",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Text Color",
      "default": "#2e4a29"
    },
    {
      "type": "color",
      "id": "closing_color",
      "label": "Closing Text Color",
      "default": "#8c9c84"
    },
    {
      "type": "header",
      "content": "Layout and Style Settings"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum Section Width",
      "default": 1300
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Overlay Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "About Us Belief"
    }
  ]
}
{% endschema %}
