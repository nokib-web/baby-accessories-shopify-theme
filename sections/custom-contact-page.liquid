<style>
  .custom-contact-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 20px;
    font-family: var(--font-body--family), sans-serif;
  }
  .custom-contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }
  @media (max-width: 900px) {
    .custom-contact-grid {
      grid-template-columns: 1fr;
    }
  }
  
  /* Left column */
  .custom-contact-left {
    padding: 20px 0;
  }
  .contact-subheading {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: {{ section.settings.subheading_color | default: '#888' }};
    margin-bottom: 15px;
    font-weight: 600;
  }
  .contact-heading {
    font-size: 2.8rem;
    color: {{ section.settings.heading_color | default: '#222' }};
    margin-top: 0;
    margin-bottom: 40px;
    font-weight: 700;
    font-family: var(--font-heading--family), sans-serif;
  }
  .contact-form-row {
    display: flex;
    gap: 20px;
  }
  @media (max-width: 600px) {
    .contact-form-row {
      flex-direction: column;
      gap: 0;
    }
  }
  .contact-form-row .form-group {
    flex: 1;
  }
  .form-group {
    margin-bottom: 25px;
    display: flex;
    flex-direction: column;
  }
  .form-group label {
    font-size: 0.95rem;
    color: #555;
    margin-bottom: 10px;
    font-weight: 500;
  }
  .form-group label span {
    color: #d9534f;
  }
  .form-group input, .form-group textarea {
    padding: 14px 16px;
    border: 1px solid #eaeaea;
    background: #fdfdfd;
    font-size: 1rem;
    width: 100%;
    box-sizing: border-box;
    font-family: inherit;
    transition: border-color 0.3s;
  }
  .form-group input:focus, .form-group textarea:focus {
    outline: none;
    border-color: #bbb;
  }
  .contact-submit-btn {
    background: {{ section.settings.button_color | default: '#cb6b51' }};
    color: #fff;
    border: none;
    padding: 16px 36px;
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    letter-spacing: 1px;
    transition: filter 0.3s;
    margin-top: 10px;
  }
  .contact-submit-btn:hover {
    filter: brightness(0.9);
  }
  .form-error {
    color: #d9534f;
    margin-bottom: 20px;
    padding: 10px;
    background: #fdf0f0;
    border: 1px solid #fadcdc;
  }
  .form-success {
    color: #5cb85c;
    margin-bottom: 20px;
    padding: 10px;
    background: #f0fdf0;
    border: 1px solid #dcfadc;
  }

  /* Right column */
  .custom-contact-right {
    background: {{ section.settings.info_bg_color | default: '#f8f4f0' }};
    padding: 50px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .contact-info-heading {
    font-size: 1.8rem;
    color: {{ section.settings.info_heading_color | default: '#222' }};
    margin-top: 0;
    margin-bottom: 40px;
    font-weight: 700;
  }
  .contact-info-item {
    display: flex;
    align-items: flex-start;
    margin-bottom: 35px;
  }
  .contact-info-item:last-child {
    margin-bottom: 0;
  }
  .contact-icon {
    width: 44px;
    height: 44px;
    background: #eae3d9;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20px;
    flex-shrink: 0;
  }
  .contact-icon svg {
    width: 20px;
    height: 20px;
    fill: #444;
  }
  .contact-text h4 {
    margin: 0 0 6px 0;
    font-size: 1.05rem;
    color: #222;
    font-weight: 700;
  }
  .contact-text p {
    margin: 0;
    font-size: 0.95rem;
    color: #555;
    line-height: 1.6;
  }
  .contact-socials {
    display: flex;
    gap: 15px;
    margin-top: 15px;
  }
  .contact-socials a {
    color: #444;
    transition: color 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-socials a:hover {
    color: #000;
  }
  .contact-socials svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
</style>

<div class="custom-contact-section">
  <div class="custom-contact-grid">
    <!-- Left Column: Form -->
    <div class="custom-contact-left">
      {% if section.settings.subheading != blank %}
        <div class="contact-subheading">{{ section.settings.subheading }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="contact-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      
      {% form 'contact' %}
        {%- if form.errors -%}
          <div class="form-error">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <div class="form-success">
            Thank you for contacting us! We will get back to you soon.
          </div>
        {%- endif -%}

        <div class="contact-form-row">
          <div class="form-group">
            <label for="ContactFormName">Your Name <span>*</span></label>
            <input type="text" id="ContactFormName" name="contact[name]" required value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
          </div>
          <div class="form-group">
            <label for="ContactFormEmail">Email Address <span>*</span></label>
            <input type="email" id="ContactFormEmail" name="contact[email]" required value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
          </div>
        </div>
        
        <div class="form-group">
          <label for="ContactFormSubject">Subject <span>*</span></label>
          <input type="text" id="ContactFormSubject" name="contact[subject]" required>
        </div>
        
        <div class="form-group">
          <label for="ContactFormMessage">Your Message <span>*</span></label>
          <textarea id="ContactFormMessage" name="contact[body]" rows="6" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        
        <button type="submit" class="contact-submit-btn">{{ section.settings.button_text | default: 'Send Message' }}</button>
      {% endform %}
    </div>

    <!-- Right Column: Info -->
    <div class="custom-contact-right">
      {% if section.settings.info_heading != blank %}
        <h3 class="contact-info-heading">{{ section.settings.info_heading }}</h3>
      {% endif %}
      
      <div class="contact-info-item">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>
        <div class="contact-text">
          <h4>Email Us</h4>
          <p><a href="mailto:{{ section.settings.email }}" style="color: inherit; text-decoration: none;">{{ section.settings.email }}</a></p>
        </div>
      </div>
      
      <div class="contact-info-item">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>
        </div>
        <div class="contact-text">
          <h4>Call Us</h4>
          <p>{{ section.settings.phone }}<br>{{ section.settings.hours }}</p>
        </div>
      </div>
      
      <div class="contact-info-item">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
        <div class="contact-text">
          <h4>Visit Us</h4>
          <p>{{ section.settings.address | newline_to_br }}</p>
        </div>
      </div>
      
      <div class="contact-info-item">
        <div class="contact-icon" style="background: transparent;">
          <!-- Empty container for alignment -->
        </div>
        <div class="contact-text">
          <h4>Follow Us</h4>
          <div class="contact-socials">
            {%- assign social_platforms = 'facebook,instagram,youtube,tiktok,twitter,threads,whatsapp,linkedin,bluesky,snapchat,pinterest,tumblr,vimeo' | split: ',' -%}
            {%- for platform in social_platforms -%}
              {%- assign link_setting = 'social_' | append: platform | append: '_link' -%}
              {%- if settings[link_setting] != blank -%}
                <a href="{{ settings[link_setting] }}" target="_blank" aria-label="{{ platform | capitalize }}">
                  <svg class="social-icons__icon" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
                    {%- render 'icon', icon: platform -%}
                  </svg>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "SEND US A MESSAGE"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#888888"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Can We Help?"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#222222"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SEND MESSAGE"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background Color",
      "default": "#cb6b51"
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "color",
      "id": "info_bg_color",
      "label": "Information Box Background",
      "default": "#f8f4f0"
    },
    {
      "type": "text",
      "id": "info_heading",
      "label": "Information Heading",
      "default": "Contact Information"
    },
    {
      "type": "color",
      "id": "info_heading_color",
      "label": "Information Heading Color",
      "default": "#222222"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "enquiries@completecosmetics.co.uk"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+44 330 330 3038"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Working Hours",
      "default": "Mon - Fri: 9AM - 6PM"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "Complete Cosmetics Limited\n50 Princes Street\nIpswich Suffolk\nIP1 1RJ\nUnited Kingdom"
    }
  ],
  "presets": [
    {
      "name": "Custom Contact Form"
    }
  ]
}
{% endschema %}
