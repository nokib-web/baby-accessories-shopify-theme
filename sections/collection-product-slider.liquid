<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>

{% liquid
  assign max_items = section.settings.max_products | default: 8
  assign section_width = section.settings.section_width | default: 'page-width'
  
  if section.settings.bg_color != blank
    render 'contrast-override', background_color: section.settings.bg_color, section_id: section.id
  endif
%}

{% if section.settings.bg_image_mobile != blank %}
  <style>
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .product-slider-section {
        background-image: url('{{ section.settings.bg_image_mobile | image_url: width: 1200 }}') !important;
      }
    }
  </style>
{% endif %}

<style>
  #shopify-section-{{ section.id }} .product-slider-section {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2400 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% elsif section.settings.bg_gradient != blank %}
      background: {{ section.settings.bg_gradient }};
    {% endif %}
    width: 100%;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .product-slider {
    min-height: {{ section.settings.min_height | default: 500 }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .product-slider-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    #shopify-section-{{ section.id }} .product-slider {
      min-height: {{ section.settings.min_height_mobile | default: 350 }}px;
    }
  }

  /* Header styles with pink line */
  .product-slider__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 32px;
  }

  .product-slider__heading {
    margin: 0 0 8px;
    font-size: {{ section.settings.heading_font_size | default: 28 }}px;
    font-weight: 600;
    color: {{ section.settings.heading_color | default: 'var(--color-foreground)' }};
    font-family: var(--font-heading--family);
  }

  @media screen and (max-width: 749px) {
    .product-slider__heading {
      font-size: {{ section.settings.heading_font_size_mobile | default: 22 }}px;
    }
  }

  .product-slider__heading-line {
    width: 60px;
    height: 3px;
    background-color: var(--color-primary-button-background);
    border-radius: 2px;
  }

  /* Carousel container & swiper wrapper styles */
  .product-slider__carousel-container {
    position: relative;
    width: 100%;
    padding: 0 48px; /* Room for arrows */
  }

  @media screen and (max-width: 749px) {
    .product-slider__carousel-container {
      padding: 0 16px;
    }
  }

  .product-slider-swiper {
    width: 100%;
    overflow: hidden;
  }

  /* Product Card Custom styling */
  .custom-prod-card {
    background: transparent;
    display: flex;
    flex-direction: column;
    position: relative;
    width: 100%;
    text-decoration: none;
    color: inherit;
  }

  .custom-prod-card__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #f7f7f7;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-prod-card__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .custom-prod-card:hover .custom-prod-card__image {
    transform: scale(1.04);
  }

  /* Badges */
  .custom-prod-card__badge-top-left {
    position: absolute;
    top: 8px;
    left: 8px;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .custom-prod-card__badge-bottom-left {
    position: absolute;
    bottom: 8px;
    left: 8px;
    z-index: 3;
  }

  .custom-prod-card__badge--green {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: #1e5c3f;
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-prod-card__badge--black {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: #111111;
    color: #ffffff;
    font-size: 8px;
    font-weight: 700;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1.1;
    text-align: center;
  }

  .custom-prod-card__badge--pink {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: #ffffff;
    border: 2px solid var(--color-primary-button-background);
    color: var(--color-primary-button-background);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-prod-card__badge--pink svg {
    width: 14px;
    height: 14px;
    stroke-width: 3;
  }

  .custom-prod-card__badge--text {
    background-color: #111111;
    color: #ffffff;
    font-size: 8px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 10px;
    text-transform: uppercase;
  }

  /* Info / price / title */
  .custom-prod-card__info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .custom-prod-card__price-row {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-primary-button-background);
    display: flex;
    gap: 6px;
    align-items: baseline;
    margin-bottom: 4px;
    font-family: var(--font-body--family);
  }

  .custom-prod-card__price-row .price-prefix {
    font-size: 11px;
    color: #666666;
    font-weight: 400;
  }

  .custom-prod-card__compare-price {
    font-size: 12px;
    color: #999999;
    text-decoration: line-through;
    font-weight: 400;
  }

  .custom-prod-card__title {
    margin: 0;
    font-size: 13px;
    color: var(--color-foreground);
    font-family: var(--font-body--family);
    font-weight: 400;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 36px;
  }

  /* Custom navigation arrows aligned vertically centered with the image card (which has aspect ratio 1:1, so about 140px from top) */
  .product-slider-arrow {
    position: absolute;
    top: 150px; /* Aligned vertically center with the 1:1 product image container */
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    color: #333333;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.2s ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
  }

  .product-slider-arrow:hover {
    background: #f7f7f7;
    border-color: #cccccc;
  }

  .product-slider-arrow.swiper-button-disabled {
    opacity: 0;
    cursor: default;
    pointer-events: none;
  }

  .product-slider-arrow--prev {
    left: 8px;
  }

  .product-slider-arrow--next {
    right: 8px;
  }

  @media screen and (max-width: 749px) {
    .product-slider-arrow {
      display: none; /* Hide arrows on mobile for swipe scroll */
    }
  }
</style>

<div class="product-slider-section">
  <div
    class="section section--{{ section_width }}{% if section_width == 'custom' %} section--page-width section--custom-width{% endif %}"
    style="
      {% if section_width == 'custom' %}
        --page-content-width: {{ section.settings.custom_max_width | default: 1400 }}px;
        --page-width: calc({{ section.settings.custom_max_width | default: 1400 }}px + (var(--page-margin) * 2));
        max-width: {{ section.settings.custom_max_width }}px;
        margin: 0 auto;
      {% endif %}
    "
  >
    <div class="product-slider">
      {%- if section.settings.heading != blank -%}
        <div class="product-slider__header">
          <h2 class="product-slider__heading">{{ section.settings.heading }}</h2>
          <div class="product-slider__heading-line"></div>
        </div>
      {%- endif -%}

      <div class="product-slider__carousel-container">
        <!-- Navigation Arrows -->
        <div class="product-slider-arrow product-slider-arrow--prev swiper-button-prev-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px; height:20px;"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </div>
        <div class="product-slider-arrow product-slider-arrow--next swiper-button-next-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px; height:20px;"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>

        <div class="swiper product-slider-swiper" id="product-slider-swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            {%- if section.settings.collection != blank and section.settings.collection.all_products_count > 0 -%}
              {%- for product in section.settings.collection.products limit: max_items -%}
                <div class="swiper-slide">
                  <div class="custom-prod-card">
                    <div class="custom-prod-card__image-wrapper">
                      <a href="{{ product.url }}" style="display: block; width: 100%; height: 100%;">
                        {%- if product.featured_image -%}
                          <img
                            class="custom-prod-card__image"
                            src="{{ product.featured_image | image_url: width: 600 }}"
                            alt="{{ product.title | escape }}"
                            loading="lazy"
                            width="300"
                            height="300"
                          >
                        {%- else -%}
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg custom-prod-card__image' }}
                        {%- endif -%}
                      </a>

                      <!-- Overlay badges -->
                      <div class="custom-prod-card__badge-top-left">
                        {%- if product.compare_at_price > product.price -%}
                          {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                          <div class="custom-prod-card__badge--black">{{ discount }}%<br>OFF*</div>
                        {%- endif -%}
                      </div>

                      <div class="custom-prod-card__badge-bottom-left">
                        <div class="custom-prod-card__badge--pink">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        </div>
                      </div>
                    </div>

                    <div class="custom-prod-card__info">
                      <div class="custom-prod-card__price-row">
                        {%- if product.price_varies -%}
                          <span class="price-prefix">from</span>
                        {%- endif -%}
                        <span>{{ product.price | money }}</span>
                        {%- if product.compare_at_price > product.price -%}
                          <span class="custom-prod-card__compare-price">{{ product.compare_at_price | money }}</span>
                        {%- endif -%}
                      </div>
                      <h3 class="custom-prod-card__title">
                        <a href="{{ product.url }}" style="text-decoration: none; color: inherit;">{{ product.title }}</a>
                      </h3>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            {%- else -%}
              <!-- Exact layout mockup placeholders from user reference screenshot -->
              {%- liquid
                assign mock_titles = "Pampers Baby-dry Size 5 42,Himalaya Baby Lotion 200ml,Bioderma Abcderm Nourishing Body Cream 200ml,Cerelac 500g Stage 1,Johnson's Natural Baby Powder 400g,Nestle Nido 3+ Growing Up Milk 900g" | split: ','
                assign mock_prices = "R 190.79,R 43.99,R 305.99,R 82.99,R 50.39,R 179.99" | split: ','
                assign mock_compare_prices = "R 264.99,R 54.99,R 339.99,,R 79.99,R 203.99" | split: ','
                assign mock_discounts = "20% OFF*,20% OFF*,,from,30% OFF*,SAVE" | split: ','
                assign mock_badges = "green+black+pink,green+black+pink,green+pink,from,green+black+pink,save" | split: ','
              -%}

              {%- for i in (0..5) -%}
                <div class="swiper-slide">
                  <div class="custom-prod-card">
                    <div class="custom-prod-card__image-wrapper">
                      <!-- Mockup placeholder image using shopify product svgs -->
                      {%- assign svg_index = i | modulo: 6 | plus: 1 -%}
                      {{ 'product-' | append: svg_index | placeholder_svg_tag: 'placeholder-svg custom-prod-card__image' }}

                      <!-- Dynamic mockup badges matching the reference screenshot exactly -->
                      {%- assign current_badges = mock_badges[i] -%}
                      <div class="custom-prod-card__badge-top-left">
                        {%- if current_badges contains 'black' -%}
                          {%- assign disc_text = mock_discounts[i] | replace: ' ', '<br>' -%}
                          <div class="custom-prod-card__badge--black">{{ disc_text }}</div>
                        {%- elsif current_badges contains 'save' -%}
                          <div class="custom-prod-card__badge--text">SAVE</div>
                        {%- endif -%}
                      </div>

                      {%- if current_badges contains 'pink' -%}
                        <div class="custom-prod-card__badge-bottom-left">
                          <div class="custom-prod-card__badge--pink">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="20 6 9 17 4 12"></polyline></svg>
                          </div>
                        </div>
                      {%- endif -%}
                    </div>

                    <div class="custom-prod-card__info">
                      <div class="custom-prod-card__price-row">
                        {%- if mock_discounts[i] == 'from' -%}
                          <span class="price-prefix">from</span>
                        {%- endif -%}
                        <span>{{ mock_prices[i] }}</span>
                        {%- if mock_compare_prices[i] != blank -%}
                          <span class="custom-prod-card__compare-price">{{ mock_compare_prices[i] }}</span>
                        {%- endif -%}
                      </div>
                      <h3 class="custom-prod-card__title">
                        <a href="#" style="text-decoration: none; color: inherit;">{{ mock_titles[i] }}</a>
                      </h3>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    function initProdSwiper() {
      var swiperContainer = document.querySelector('#product-slider-swiper-{{ section.id }}');
      if (!swiperContainer) return;
      
      if (typeof Swiper === 'undefined') {
        setTimeout(initProdSwiper, 100);
        return;
      }
      
      if (swiperContainer.swiper) {
        swiperContainer.swiper.destroy(true, true);
      }
      
      new Swiper(swiperContainer, {
        slidesPerView: 4,
        spaceBetween: 16,
        loop: true,
        navigation: {
          nextEl: '.swiper-button-next-{{ section.id }}',
          prevEl: '.swiper-button-prev-{{ section.id }}',
        },
        breakpoints: {
          320: {
            slidesPerView: 1.3,
            spaceBetween: 12
          },
          480: {
            slidesPerView: 2.2,
            spaceBetween: 12
          },
          768: {
            slidesPerView: 3,
            spaceBetween: 16
          },
          1024: {
            slidesPerView: 4,
            spaceBetween: 16
          }
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProdSwiper);
    } else {
      initProdSwiper();
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === '{{ section.id }}') {
        setTimeout(initProdSwiper, 100);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Collection Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Save Big on Baby Essentials"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size (desktop)",
      "min": 16,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading Font Size (mobile)",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products to display",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "custom",
          "label": "Custom Max Width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "custom_max_width",
      "label": "Custom Max Width",
      "min": 1000,
      "max": 2000,
      "step": 10,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum Height (desktop)",
      "min": 200,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Minimum Height (mobile)",
      "min": 150,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 350
    },
    {
      "type": "header",
      "content": "Background Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background Image (mobile override)"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Background Gradient"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Collection Product Slider"
    }
  ]
}
{% endschema %}
