        "trad_title": "Traditional Baby Shoes",
        "trad_image": "shopify://shop_images/images_3.webp",
        "trad_item_1_title": "Narrow Toe Box",
        "trad_item_1_desc": "Pinches baby toes, leading to misalignment, blisters, and potential future foot deformities.",
        "trad_item_2_title": "Stiff & Heavy Soles",
        "trad_item_2_desc": "Restricts natural foot flexing. Weakens arches and ankle muscles, causing dependency on shoe support.",
        "trad_item_3_title": "Elevated Heels (Drop)",
        "trad_item_3_desc": "Alters natural posture, throwing off body balance and putting unnecessary stress on toddler knees and hips.",
        "bf_title": "Little Leaf Barefoot Shoes",
        "bf_image": "shopify://shop_images/AngelBanner_1.webp",
        "badge_label": "Healthy Growth",
        "bf_item_1_title": "Wide, Foot-Shaped Toe Box",
        "bf_item_1_desc": "Gives toes ample room to splay naturally, providing excellent stability, balance, and straight toe alignment.",
        "bf_item_2_title": "Ultra-Flexible, Thin Soles",
        "bf_item_2_desc": "Rolls easily in any direction. Mimics walking barefoot to build natural foot strength, arch structure, and sensory feedback.",
        "bf_item_3_title": "Zero Heel-to-Toe Drop",
        "bf_item_3_desc": "Flat sole design supports natural alignment of spine, hips, and knees. Fosters ideal walking posture.",
        "cta_link": "shopify://collections/hopfrog-barefoot-shoes-multimix",
        "cta_label": "Shop Healthy Barefoot Shoes",
        "bg_color": "#f4f6f1",
        "section_width": "custom",
        "custom_max_width": 1600,
        "padding_top": 64,
        "padding_bottom": 64,
        "padding_top_mobile": 48,
        "padding_bottom_mobile": 48
