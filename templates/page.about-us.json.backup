    },
    "about_organic": {
      "type": "about-us-split-list",
      "blocks": {
        "org_1": {
          "type": "list_item",
          "settings": {
            "title": "Gentle Where It Matters Most",
            "text": "Our babywear is made from GOTS-certified organic cotton — a certification that ensures the entire process, from farming to final garment, avoids harsh chemicals, toxic dyes and irritants. The result is not only softer fabric, but calmer comfort."
          }
        },
        "org_2": {
          "type": "list_item",
          "settings": {
            "title": "Safe, Comfort, Naturally",
            "text": "Babies explore the world with their mouths — which is why our teethers are 100% natural. Made from pure natural materials and free from gels, plastics and hidden fillers, they offer soothing relief."
          }
        },
        "org_3": {
          "type": "list_item",
          "settings": {
            "title": "More Than Clothing — A Beginning",
            "text": "Choosing organic is not about perfection. It’s about intention. By surrounding your baby with natural materials you are reducing exposure to unnecessary chemicals, supporting responsible farming and ethical production."
          }
        }
      },
      "block_order": [
        "org_1",
        "org_2",
        "org_3"
      ],
      "settings": {
        "title": "Why Organic?",
        "image_alignment": "left",
        "image_shape": "blob_1",
        "max_width": 1600,
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "about_barefoot": {
      "type": "about-us-split-list",
      "blocks": {
        "bf_1": {
          "type": "list_item",
          "settings": {
            "title": "Made to Move Naturally",
            "text": "Our barefoot shoes support natural foot movement, building strength and balance from the ground up."
          }
        },
        "bf_2": {
          "type": "list_item",
          "settings": {
            "title": "Why Barefoot Matters",
            "text": "Wide toe boxes, flexible soles, and zero drop — helping little feet grow strong and healthy."
          }
        },
        "bf_3": {
          "type": "list_item",
          "settings": {
            "title": "Designed for Growing Feet",
            "text": "Lightweight, breathable, and thoughtfully crafted for every adventure, every day."
          }
        }
      },
      "block_order": [
        "bf_1",
        "bf_2",
        "bf_3"
      ],
      "settings": {
        "title": "Barefoot Shoes — Natural Steps, Healthy Development",
        "image_alignment": "right",
        "image_shape": "blob_2",
        "max_width": 1600,
        "background_image": "shopify://shop_images/leafy-background-pattern.png",
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "about_modal": {
      "type": "about-us-split-list",
      "blocks": {
        "md_1": {
          "type": "list_item",
          "settings": {
            "title": "Why Modal Matters",
            "text": "Modal is ultra soft, breathable and gentle on sensitive skin — perfect for everyday comfort."
          }
        },
        "md_2": {
          "type": "list_item",
          "settings": {
            "title": "Gentle and Thoughtfully Produced",
            "text": "Made from beech tree fibers using eco-friendly processes that are better for baby and the planet."
          }
        },
        "md_3": {
          "type": "list_item",
          "settings": {
            "title": "Comfort That Lasts",
            "text": "Smooth, durable, and designed to keep your little one cozy all day and night."
          }
        }
      },
      "block_order": [
        "md_1",
        "md_2",
        "md_3"
      ],
      "settings": {
        "title": "Modal — Silky Soft, Naturally Gentle",
        "image_alignment": "left",
        "image_shape": "blob_1",
        "max_width": 1600,
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "about_belief": {
      "type": "about-us-belief",
      "settings": {
        "title": "Our Belief",
        "text": "<p>We believe in natural. We believe in gentle. We believe in growing little ones the right way — with love, care, and conscious choices.</p>",
        "highlight_text": "For your baby. For your family. For the world they'll grow up in. ♥",
        "closing_text": "Because the gentlest beginnings leave the deepest impressions.",
        "max_width": 1600,
        "background_image": "shopify://shop_images/leafy-background-pattern.png",
        "padding_top": 80,
        "padding_bottom": 80
      }
    }
