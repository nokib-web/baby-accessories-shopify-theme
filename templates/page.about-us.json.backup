    "about_hero": {
      "type": "about-us-hero",
      "settings": {
        "subtitle": "NATURAL. GENTLE. THOUGHTFUL.",
        "title": "Welcome to Little Leaf Baby Company",
        "text": "<p>At Little Leaf Baby Company, we believe that the gentlest touch begins with nature. We're passionate about providing South African parents with premium quality, baby essentials responsibly sourced and consciously crafted from organic and natural materials that are as kind to your baby's delicate skin as they are to our planet.</p>",
        "btn_1_label": "Shop Our Range",
        "btn_1_link": "shopify://collections/all",
        "btn_2_label": "Our Story",
        "btn_2_link": "shopify://pages/about-us-1",
        "show_leaf_icons": true,
        "max_width": 1600,
        "background_image": "shopify://shop_images/leafy-background-pattern.png",
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "about_promise": {
      "type": "about-us-promise",
      "settings": {
        "title": "Our Promise",
        "text": "<p>Every product in our collection is thoughtfully selected with your baby's wellbeing and environmental responsibility in mind.  We curate each item with care, ensuring it meets our high standards for quality, safety, and sustainability. From organic cotton babywear to natural teethers, every product reflects our commitment to conscious parenting and a healthier planet.</p>",
        "max_width": 1000,
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "about_specialties": {
      "type": "about-us-specialties",
      "blocks": {
