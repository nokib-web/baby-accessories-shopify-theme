              "name": "t:names.heading",
              "settings": {
                "text": "<h2>Natural Foot Development for Growing Children</h2>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "h3",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
