<div
  class="trust-badges-block"
  style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 16px;
    margin-top: {{ block.settings.margin_top }}px;
    border: 1px solid rgba(var(--color-foreground-rgb, 0,0,0), 0.1);
    border-radius: 8px;
    background-color: var(--color-background-secondary);
  "
  {{ block.shopify_attributes }}
>
  {% for i in (1..4) %}
    {% capture icon_key %}icon_{{ i }}{% endcapture %}
    {% capture image_key %}icon_image_{{ i }}{% endcapture %}
    {% capture text_key %}text_{{ i }}{% endcapture %}
    
    {% assign icon = block.settings[icon_key] %}
    {% assign custom_image = block.settings[image_key] %}
    {% assign text = block.settings[text_key] %}
    {% if text == "Free UK Delivery over £25" %}
      {% assign text = "Free Shipping in SA" %}
    {% elsif text == "14-Day Easy Returns" %}
      {% assign text = "Easy Returns & Exchanges" %}
    {% elsif text == "Authentic Beauty Guarantee" %}
      {% assign text = "100% Organic & Baby Safe" %}
    {% endif %}

    {% if text != blank %}
      <div class="trust-badge-item" style="display: flex; flex-direction: row; align-items: center; text-align: left; gap: 10px;">
        {% if custom_image != blank %}
          <div class="trust-badge-icon" style="width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <img src="{{ custom_image | image_url: width: 100 }}" alt="{{ text | escape }}" style="width: 100%; height: 100%; object-fit: contain;" loading="lazy">
          </div>
        {% elsif icon != 'none' %}
          <div class="trust-badge-icon" style="width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px; color: {{ block.settings.icon_color | default: '#2e4a29' }}; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            {% render 'icon', icon: icon %}
          </div>
        {% endif %}
        <span class="trust-badge-text" style="font-size: {{ block.settings.font_size }}px; font-weight: 500; line-height: 1.2; color: var(--color-foreground); opacity: 0.9;">
          {{ text }}
        </span>
      </div>
    {% endif %}
  {% endfor %}
</div>

