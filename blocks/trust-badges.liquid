<div
  class="trust-badges-block"
  style="
    display: flex;
    justify-content: {{ block.settings.alignment }};
    gap: {{ block.settings.gap }}px;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    border-top: {% if block.settings.show_top_border %}1px solid rgba(var(--color-foreground-rgb, 0,0,0), 0.1){% else %}none{% endif %};
  "
  {{ block.shopify_attributes }}
>
  {% for i in (1..3) %}
    {% capture icon_key %}icon_{{ i }}{% endcapture %}
    {% capture text_key %}text_{{ i }}{% endcapture %}
    
    {% assign icon = block.settings[icon_key] %}
    {% assign text = block.settings[text_key] %}

    {% if text != blank %}
      <div class="trust-badge-item" style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 4px; flex: 1;">
        {% if icon != 'none' %}
          <div class="trust-badge-icon" style="width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px; color: {{ block.settings.icon_color | default: 'inherit' }};">
            {% render 'icon', icon: icon %}
          </div>
        {% endif %}
        <span class="trust-badge-text" style="font-size: {{ block.settings.font_size }}px; font-weight: 500; line-height: 1.2; color: var(--color-foreground); opacity: 0.8;">
          {{ text }}
        </span>
      </div>
    {% endif %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "select",
      "id": "icon_1",
      "label": "Icon 1",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "truck", "label": "Delivery Truck" },
        { "value": "shield-check", "label": "Shield Check" },
        { "value": "return", "label": "Return Arrow" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "heart", "label": "Heart" },
        { "value": "star", "label": "Star" },
        { "value": "lock", "label": "Lock" }
      ],
      "default": "truck"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text 1",
      "default": "Free Delivery"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "select",
      "id": "icon_2",
      "label": "Icon 2",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "truck", "label": "Delivery Truck" },
        { "value": "shield-check", "label": "Shield Check" },
        { "value": "return", "label": "Return Arrow" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "heart", "label": "Heart" },
        { "value": "star", "label": "Star" },
        { "value": "lock", "label": "Lock" }
      ],
      "default": "shield-check"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text 2",
      "default": "Secure Checkout"
    },
    {
      "type": "header",
      "content": "Badge 3"
    },
    {
      "type": "select",
      "id": "icon_3",
      "label": "Icon 3",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "truck", "label": "Delivery Truck" },
        { "value": "shield-check", "label": "Shield Check" },
        { "value": "return", "label": "Return Arrow" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "heart", "label": "Heart" },
        { "value": "star", "label": "Star" },
        { "value": "lock", "label": "Lock" }
      ],
      "default": "return"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text 3",
      "default": "Easy Returns"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "space-between", "label": "Space Between" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Text Size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Spacing Between Badges",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_top_border",
      "label": "Show top divider border",
      "default": true
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top Margin",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Trust Badges"
    }
  ]
}
{% endschema %}
