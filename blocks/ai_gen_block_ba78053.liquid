{% doc %}
  @prompt
    Add a privacy policy link to the password footer section. The link should point to /policies/privacy-policy and display text "Privacy Policy". Style it to match the existing footer design, keeping it subtle and minimal to suit a premium brand aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-privacy-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-align: center;
    padding: {{ block.settings.spacing_top }}px 20px {{ block.settings.spacing_bottom }}px;
  }

  .ai-privacy-link-{{ ai_gen_id }}__link {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    text-decoration: none;
    opacity: {{ block.settings.opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-privacy-link-{{ ai_gen_id }}__link:hover {
    opacity: 1;
    text-decoration: {{ block.settings.hover_underline }};
  }

  @media screen and (max-width: 749px) {
    .ai-privacy-link-{{ ai_gen_id }}__link {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-privacy-link-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <a href="/policies/privacy-policy" class="ai-privacy-link-{{ ai_gen_id }}__link">
    {{ block.settings.link_text }}
  </a>
</div>

{% schema %}
{
  "name": "Privacy policy link",
  "settings": [
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Privacy Policy"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#091208"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "inter_n4"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 2,
      "step": 0.1,
      "unit": "px",
      "default": 0.5
    },
    {
      "type": "range",
      "id": "opacity",
      "label": "Opacity",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 60
    },
    {
      "type": "select",
      "id": "hover_underline",
      "label": "Hover underline",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "underline",
          "label": "Underline"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Privacy policy link"
    }
  ]
}
{% endschema %}
