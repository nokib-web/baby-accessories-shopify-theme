{% doc %}
  @prompt
    Fix the Image gallery showcase block where text/words are being cut off on the sides on mobile. Add CSS to ensure text within the image gallery showcase has sufficient horizontal padding, no overflow clipping, and wraps correctly so no words are cut off on either side of the screen.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gallery-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
  }

  .ai-gallery-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-gallery-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    aspect-ratio: {{ block.settings.aspect_ratio }};
  }

  .ai-gallery-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-gallery-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    transition: opacity 0.3s ease;
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover .ai-gallery-overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_hover_opacity }};
  }

  .ai-gallery-content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.text_vertical_alignment }};
    align-items: {{ block.settings.text_horizontal_alignment }};
    padding: {{ block.settings.text_padding_desktop }}px;
    text-align: {{ block.settings.text_alignment }};
    z-index: 1;
    box-sizing: border-box;
    overflow: hidden;
  }

  .ai-gallery-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 8px 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
    max-width: 100%;
  }

  .ai-gallery-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
    max-width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-gallery-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
      width: 100%;
      padding: {{ block.settings.section_padding_mobile }}px 0;
    }

    .ai-gallery-content-{{ ai_gen_id }} {
      padding: {{ block.settings.text_padding_mobile }}px;
    }

    .ai-gallery-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-gallery-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }
  }
{% endstyle %}

<image-gallery-showcase-{{ ai_gen_id }}
  class="ai-gallery-showcase-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-gallery-container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign description_key = 'description_' | append: i
        assign link_key = 'link_' | append: i

        assign image = block.settings[image_key]
        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
        assign link = block.settings[link_key]
      %}

      {% if image != blank or title != blank or description != blank %}
        <div class="ai-gallery-item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" style="display: block; width: 100%; height: 100%;">
          {% endif %}

          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-gallery-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-gallery-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="ai-gallery-overlay-{{ ai_gen_id }}"></div>

          {% if title != blank or description != blank %}
            <div class="ai-gallery-content-{{ ai_gen_id }}">
              {% if title != blank %}
                <h3 class="ai-gallery-title-{{ ai_gen_id }}">{{ title }}</h3>
              {% endif %}
              {% if description != blank %}
                <p class="ai-gallery-description-{{ ai_gen_id }}">{{ description }}</p>
              {% endif %}
            </div>
          {% endif %}

          {% if link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</image-gallery-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageGalleryShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('image-gallery-showcase-{{ ai_gen_id }}', ImageGalleryShowcase{{ ai_gen_id }});
  })();
</script>

