{% doc %}
  @prompt
    Add a row of policy links at the bottom of the password page. Include links to Privacy Policy (/policies/privacy-policy), Refund Policy (/policies/refund-policy), Shipping Policy (/policies/shipping-policy), and Terms of Service (/policies/terms-of-service). The links must be self-contained and fully rendered in the block output. Style them centered, small font, muted color, minimal — suited to a premium eco-friendly baby brand.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-policy-links-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.vertical_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-policy-links__container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.link_spacing }}px;
    margin: 0 auto;
  }

  .ai-policy-links__link-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
    opacity: {{ block.settings.link_opacity }};
    white-space: nowrap;
  }

  .ai-policy-links__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    opacity: 1;
  }

  .ai-policy-links__separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    opacity: {{ block.settings.separator_opacity }};
    font-size: {{ block.settings.font_size }}px;
    user-select: none;
  }

  @media screen and (max-width: 749px) {
    .ai-policy-links__container-{{ ai_gen_id }} {
      gap: {{ block.settings.link_spacing | times: 0.8 }}px;
    }

    .ai-policy-links__link-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-policy-links__separator-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-policy-links-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <nav class="ai-policy-links__container-{{ ai_gen_id }}" aria-label="Policy links">
    <a href="/policies/privacy-policy" class="ai-policy-links__link-{{ ai_gen_id }}">
      Privacy Policy
    </a>
    <span class="ai-policy-links__separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
    <a href="/policies/refund-policy" class="ai-policy-links__link-{{ ai_gen_id }}">
      Refund Policy
    </a>
    <span class="ai-policy-links__separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
    <a href="/policies/shipping-policy" class="ai-policy-links__link-{{ ai_gen_id }}">
      Shipping Policy
    </a>
    <span class="ai-policy-links__separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
    <a href="/policies/terms-of-service" class="ai-policy-links__link-{{ ai_gen_id }}">
      Terms of Service
    </a>
  </nav>
</div>

{% schema %}
{
  "name": "Policy links",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "link_spacing",
      "label": "Link spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "·"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#1f2937"
    },
    {
      "type": "range",
      "id": "link_opacity",
      "label": "Link opacity",
      "min": 0.5,
      "max": 1,
      "step": 0.1,
      "default": 0.7
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#9ca3af"
    },
    {
      "type": "range",
      "id": "separator_opacity",
      "label": "Separator opacity",
      "min": 0.3,
      "max": 1,
      "step": 0.1,
      "default": 0.5
    }
  ],
  "presets": [
    {
      "name": "Policy links"
    }
  ]
}
{% endschema %}
