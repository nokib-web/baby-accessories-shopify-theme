{%- if block.settings.input_style == 'custom' -%}
  {%- capture wrapper_class -%}quantity-selector-wrapper--block-{{ block.id }}{%- endcapture -%}
  <style>
    .{{ wrapper_class }} {
      {%- render 'input-custom-styles', block_settings: block.settings -%}
      --style-border-width-inputs: {{ block.settings.border_width }}px;
      --style-border-radius-inputs: {{ block.settings.border_radius }}px;
      --style-border-radius-buttons-primary: {{ block.settings.border_radius }}px;
      --style-border-radius-buttons-secondary: {{ block.settings.border_radius }}px;
    }
  </style>
{%- endif -%}

<style>
  .product-quantity-wrapper {
    display: flex !important;
    align-items: center !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    width: 100% !important;
  }
  
  .shopify-block:has(.product-quantity-wrapper) {
    flex: 1 0 100% !important;
    width: 100% !important;
    display: block !important;
  }

  .product-quantity-label {
    font-weight: bold !important;
    width: 140px !important;
    min-width: 140px !important;
    max-width: 140px !important;
    color: var(--color-foreground) !important;
    font-size: 14px !important;
  }

  .product-quantity-wrapper .quantity-selector-wrapper {
    display: flex !important;
    align-items: center !important;
    width: 120px !important;
    min-width: 120px !important;
    max-width: 120px !important;
    flex: 0 0 120px !important;
    margin: 0 !important;
  }

  .product-quantity-wrapper .quantity-selector {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    width: 120px !important;
    min-width: 120px !important;
    max-width: 120px !important;
    flex: 0 0 120px !important;
    height: 36px !important;
    border: 1px solid #ddd !important;
    border-radius: 0px !important;
    background: #fff !important;
    padding: 0 !important;
    overflow: hidden !important;
  }

  .product-quantity-wrapper .quantity-selector :is(.quantity-minus, .quantity-plus) {
    width: 36px !important;
    height: 36px !important;
    flex: 0 0 36px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: transparent !important;
    border: none !important;
    border-radius: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    color: #c62828 !important;
    cursor: pointer !important;
  }

  .product-quantity-wrapper .quantity-selector :is(.quantity-minus, .quantity-plus) svg {
    width: 12px !important;
    height: 12px !important;
    color: #c62828 !important;
  }

  .product-quantity-wrapper .quantity-selector .quantity-minus {
    border-right: 1px solid #ddd !important;
  }

  .product-quantity-wrapper .quantity-selector .quantity-plus {
    border-left: 1px solid #ddd !important;
  }

  .product-quantity-wrapper .quantity-selector input[type='number'] {
    width: 46px !important;
    max-width: 46px !important;
    flex: 1 1 auto !important;
    height: 36px !important;
    border: none !important;
    border-radius: 0 !important;
    text-align: center !important;
    background: transparent !important;
    margin: 0 !important;
    padding: 0 !important;
    color: #111 !important;
    font-size: 15px !important;
  }
</style>

<div class="product-quantity-wrapper" {{ block.shopify_attributes }}>
  <span class="product-quantity-label">Quantity:</span>
  {% render 'quantity-selector', product: closest.product, block: block, wrapper_class: wrapper_class %}
</div>

{% schema %}
{
  "name": "t:names.quantity",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.input"
    },
    {
      "type": "select",
      "id": "input_style",
      "label": "t:settings.style",
      "options": [
        {
          "value": "default",
          "label": "t:options.default"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "default",
      "info": "t:info.edit_input_field_in_theme_settings"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "t:settings.background",
      "default": "{{ settings.color_palette.background }}",
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    },
    {
      "type": "color",
      "id": "input_text_color",
      "label": "t:settings.text",
      "default": "{{ settings.color_palette.foreground }}",
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "t:settings.borders",
      "default": "{{ settings.color_palette.foreground }}",
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "t:settings.border_width",
      "min": 0,
      "max": 4,
      "step": 0.5,
      "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.quantity",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
