      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "About Us"
    },
    {
      "type": "page",
      "id": "about_page",
      "label": "Page"
    },
    {
      "type": "text",
      "id": "about_label",
      "label": "Label",
      "default": "About Us"
    },
    {
      "type": "header",
      "content": "Contact Us"
    },
    {
      "type": "page",
      "id": "contact_page",
      "label": "Page"
    },
    {
      "type": "text",
      "id": "contact_label",
