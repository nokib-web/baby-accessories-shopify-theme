{% doc %}
  @prompt
    i want to add the page links for About Us, Contact Us and FAQ
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-page-links-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-page-links-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.link_spacing }}px;
    align-items: {{ block.settings.alignment }};
    justify-content: {{ block.settings.justify }};
    flex-wrap: wrap;
  }

  .ai-page-links-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.text_align }};
  }

  .ai-page-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.link_padding_vertical }}px {{ block.settings.link_padding_horizontal }}px;
    background-color: {{ block.settings.link_background }};
    color: {{ block.settings.link_color }};
    text-decoration: none;
    border-radius: {{ block.settings.link_border_radius }}px;
    border: {{ block.settings.link_border_width }}px solid {{ block.settings.link_border_color }};
    font-size: {{ block.settings.link_font_size }}px;
    transition: all 0.3s ease;
  }

  .ai-page-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.link_hover_background }};
    color: {{ block.settings.link_hover_color }};
    border-color: {{ block.settings.link_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-page-link-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-page-link-empty-{{ ai_gen_id }} {
    padding: 20px;
    text-align: center;
    color: #999;
    font-size: 14px;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-page-links-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-page-link-{{ ai_gen_id }} {
      width: 100%;
      justify-content: center;
    }
  }
{% endstyle %}

<div class="ai-page-links-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-page-links-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-page-links-container-{{ ai_gen_id }}">
    {% if block.settings.about_page != blank %}
      <a href="{{ block.settings.about_page.url }}" class="ai-page-link-{{ ai_gen_id }}">
        {% if block.settings.show_icons %}
          <svg class="ai-page-link-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        {% endif %}
        <span>{{ block.settings.about_label }}</span>
      </a>
    {% endif %}

    {% if block.settings.contact_page != blank %}
      <a href="{{ block.settings.contact_page.url }}" class="ai-page-link-{{ ai_gen_id }}">
        {% if block.settings.show_icons %}
          <svg class="ai-page-link-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        {% endif %}
        <span>{{ block.settings.contact_label }}</span>
      </a>
    {% endif %}

    {% if block.settings.faq_page != blank %}
      <a href="{{ block.settings.faq_page.url }}" class="ai-page-link-{{ ai_gen_id }}">
        {% if block.settings.show_icons %}
          <svg class="ai-page-link-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
        {% endif %}
        <span>{{ block.settings.faq_label }}</span>
      </a>
    {% endif %}

    {% if block.settings.about_page == blank and block.settings.contact_page == blank and block.settings.faq_page == blank %}
      <div class="ai-page-link-empty-{{ ai_gen_id }}">
        Next, select pages for About Us, Contact Us, and FAQ
      </div>
    {% endif %}
  </div>
</div>

