    {
      "type": "text",
      "id": "caption_1",
      "label": "Caption 1"
    },
    {
      "type": "text",
      "id": "caption_2",
      "label": "Caption 2"
    },
    {
      "type": "text",
      "id": "caption_3",
      "label": "Caption 3"
    },
    {
      "type": "text",
      "id": "caption_4",
      "label": "Caption 4"
    },
    {
      "type": "range",
