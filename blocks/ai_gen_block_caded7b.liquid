{% doc %}
  @prompt
    Create an image gallery showcase block for the password page with multiple image picker fields (3-4 slots) so the merchant can upload their own custom images from their files. Each image slot should have an optional text label beneath it. The design should be clean, minimal, and earthy to suit a premium eco-friendly baby brand, with a color scheme 4 background. No product catalog integration needed — purely custom uploaded images with optional captions.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gallery-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-gallery-showcase__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-gallery-showcase__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-gallery-showcase__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-gallery-showcase__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.caption_spacing }}px;
  }

  .ai-gallery-showcase__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-gallery-showcase__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-gallery-showcase__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-gallery-showcase__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-gallery-showcase__caption-{{ ai_gen_id }} {
    text-align: {{ block.settings.caption_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_size }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-gallery-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-gallery-showcase__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<gallery-showcase-{{ ai_gen_id }}
  class="ai-gallery-showcase-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-gallery-showcase__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-gallery-showcase__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    <div class="ai-gallery-showcase__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign caption_key = 'caption_' | append: i
          assign image = block.settings[image_key]
          assign caption = block.settings[caption_key]
        %}

        <div class="ai-gallery-showcase__item-{{ ai_gen_id }}">
          <div class="ai-gallery-showcase__image-wrapper-{{ ai_gen_id }}">
            {% if image != blank %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-gallery-showcase__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-gallery-showcase__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if caption != blank %}
            <div class="ai-gallery-showcase__caption-{{ ai_gen_id }}">
              {{ caption }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</gallery-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class GalleryShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('gallery-showcase-{{ ai_gen_id }}', GalleryShowcase{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image gallery showcase",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
