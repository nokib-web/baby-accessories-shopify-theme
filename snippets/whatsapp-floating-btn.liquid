{% liquid
  assign whatsapp_num = settings.whatsapp_number | default: '27123456789' | remove: '+' | remove: ' ' | remove: '-'
  assign whatsapp_message = settings.whatsapp_default_message | default: 'Hello Little Leaf Baby Co! I have an inquiry about your products.' | url_encode
  assign whatsapp_url = 'https://wa.me/' | append: whatsapp_num | append: '?text=' | append: whatsapp_message
%}

<a
  href="{{ whatsapp_url }}"
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-widget"
  aria-label="Chat with us on WhatsApp"
>
  <!-- Notification Red Badge -->
  <span class="whatsapp-widget__badge">1</span>

  <!-- Tooltip Message Bubble -->
  <div class="whatsapp-widget__tooltip">
    <div class="whatsapp-widget__status">
      <span class="whatsapp-widget__dot"></span>
      <span class="whatsapp-widget__status-text">Little Leaf Support</span>
    </div>
    <div class="whatsapp-widget__text">Need help? Chat with us on WhatsApp 👋</div>
  </div>

  <!-- WhatsApp Circular Button -->
  <div class="whatsapp-widget__button">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="whatsapp-widget__icon" aria-hidden="true">
      <path fill="#ffffff" d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3 18.6-68.1-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
    </svg>
  </div>
</a>

<style>
  .whatsapp-widget {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 999999;
    display: flex;
    align-items: center;
    text-decoration: none;
    cursor: pointer;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    -webkit-tap-highlight-color: transparent;
  }

  /* Circular Button */
  .whatsapp-widget__button {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: #25D366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 18px rgba(37, 211, 102, 0.45), 0 2px 8px rgba(0, 0, 0, 0.15);
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.25s ease;
    position: relative;
    z-index: 2;
  }

  .whatsapp-widget__icon {
    width: 34px;
    height: 34px;
    display: block;
  }

  /* Red Badge Dot */
  .whatsapp-widget__badge {
    position: absolute;
    top: -2px;
    right: -2px;
    z-index: 3;
    background-color: #ff3b30;
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #ffffff;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
    animation: wa-badge-bounce 2.5s infinite ease-in-out;
  }

  /* Tooltip Box */
  .whatsapp-widget__tooltip {
    position: absolute;
    right: 72px;
    background: #ffffff;
    border-radius: 12px;
    padding: 10px 14px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.14);
    border: 1px solid #eaeaea;
    width: 220px;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transform: translateX(12px) scale(0.95);
    transition: all 0.25s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: 1;
  }

  .whatsapp-widget__tooltip::after {
    content: '';
    position: absolute;
    top: 50%;
    right: -6px;
    transform: translateY(-50%);
    border-width: 6px 0 6px 6px;
    border-style: solid;
    border-color: transparent transparent transparent #ffffff;
  }

  .whatsapp-widget__status {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 4px;
  }

  .whatsapp-widget__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #25D366;
    box-shadow: 0 0 0 2px rgba(37, 211, 102, 0.3);
  }

  .whatsapp-widget__status-text {
    font-size: 11px;
    font-weight: 700;
    color: #25D366;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .whatsapp-widget__text {
    font-size: 13px;
    color: #222222;
    line-height: 1.35;
    font-weight: 500;
  }

  /* Hover & Active States */
  .whatsapp-widget:hover .whatsapp-widget__button {
    transform: scale(1.08);
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.6);
  }

  .whatsapp-widget:hover .whatsapp-widget__tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(0) scale(1);
  }

  @keyframes wa-badge-bounce {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.18);
    }
  }

  /* Mobile Adjustments */
  @media screen and (max-width: 749px) {
    .whatsapp-widget {
      bottom: 20px;
      right: 20px;
    }

    .whatsapp-widget__button {
      width: 54px;
      height: 54px;
    }

    .whatsapp-widget__icon {
      width: 30px;
      height: 30px;
    }

    .whatsapp-widget__tooltip {
      display: none;
    }
  }
</style>
