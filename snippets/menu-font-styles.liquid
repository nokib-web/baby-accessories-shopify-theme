{%- doc -%}
  Derives CSS variables from the menu typography settings for 1st level/main menu items.

  @param {object} settings - The block settings object containing typography settings.
  @param {string} menu_type - The menu type: 'drawer' or 'mega_menu'.
{%- enddoc -%}

--menu-top-level-font-family: var(--font-{{ settings.type_font_primary_link }}--family);
--menu-top-level-font-size-desktop: {{ settings.type_font_primary_size_px }}px;
--menu-top-level-font-style: var(--font-{{- settings.type_font_primary_link -}}--style);
{% if settings.menu_font_weight != blank %}
  --menu-top-level-font-weight: {{ settings.menu_font_weight }};
{% else %}
  --menu-top-level-font-weight: var(--font-{{- settings.type_font_primary_link -}}--weight);
{% endif %}
--menu-top-level-font-case: {%- if settings.type_case_primary_link == 'uppercase' %}uppercase{% else %}none{% endif -%};
{% if menu_type == 'drawer' %}
  --menu-top-level-font-size: var(--menu-font-2xl--size);
  --menu-top-level-font-line-height: var(--menu-font-2xl--line-height);
{% else %}
  --menu-top-level-font-size: {{ settings.type_font_primary_size_px }}px;
  --menu-top-level-font-line-height: var(--menu-font-sm--line-height);
{% endif %}
{% if settings.text_color != blank and settings.text_color.alpha != 0 %}
  --menu-top-level-font-color: {{ settings.text_color }};
  --menu-top-level-font-color-rgb: {{ settings.text_color.rgb }};
{% else %}
  --menu-top-level-font-color: var(--color-foreground);
  --menu-top-level-font-color-rgb: var(--color-foreground-rgb);
{% endif %}
--menu-top-level-font-hover-color: {{ settings.hover_color | default: '#2e4a29' }};
--menu-top-level-active-bg: {{ settings.active_background_color | default: '#e2e5d0' }};
--menu-top-level-active-color: {{ settings.active_text_color | default: '#2e4a29' }};
--menu-top-level-border-radius: {{ settings.menu_item_border_radius | default: 6 }}px;
